<Window x:Class="ImageViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ImageViewer"
        xmlns:vm="clr-namespace:ImageViewer.ViewModel"
        mc:Ignorable="d"
        Title="图片查看器" MinHeight="450" MinWidth="800">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="StatusBarFontStyle" TargetType="StatusBar">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>

        <!-- 图片缩放渲染选项 -->
        <Style TargetType="Image">
            <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- 工具栏区域 -->
        <Grid DockPanel.Dock="Top">
            <StackPanel Orientation="Vertical">
                <Menu>
                    <MenuItem Header="文件">
                        <MenuItem Header="打开图片..." Command="{Binding OpenFileCommand}"/>
                        <Separator/>
                        <MenuItem Header="退出" Command="{Binding ExitCommand}"/>
                    </MenuItem>
                    <MenuItem Header="查看">
                        <MenuItem Header="实际大小" Command="{Binding ActualSizeCommand}"/>
                        <MenuItem Header="适应窗口" Command="{Binding FitToWindowCommand}"/>
                    </MenuItem>
                    <MenuItem Header="工具"/>
                    <MenuItem Header="帮助">
                        <MenuItem Header="关于" Command="{Binding AboutCommand}"/>
                    </MenuItem>
                </Menu>

                <Separator/>

                <ToolBar>
                    <Button Content="打开" Command="{Binding OpenFileCommand}" ToolTip="打开图片"/>
                    <Separator/>
                    <Button Content="上一张" Command="{Binding PreviousImageCommand}" ToolTip="上一张图片"/>
                    <Button Content="下一张" Command="{Binding NextImageCommand}" ToolTip="下一张图片"/>
                    <Separator/>
                    <Button Content="放大" Command="{Binding ZoomInCommand}" ToolTip="放大"/>
                    <Button Content="缩小" Command="{Binding ZoomOutCommand}" ToolTip="缩小"/>
                    <Button Content="全屏" Command="{Binding FullScreenCommand}" ToolTip="全屏"/>
                    <Separator/>
                    <Button Content="↺" Command="{Binding RotateLeftCommand}" ToolTip="逆时针旋转"/>
                    <Button Content="↻" Command="{Binding RotateRightCommand}" ToolTip="顺时针旋转"/>
                    <Separator/>
                    <Button Content="删除" Command="{Binding DeleteImageCommand}" ToolTip="删除图片"/>
                </ToolBar>
            </StackPanel>
        </Grid>

        <!-- 主内容区域 -->
        <Grid DockPanel.Dock="Bottom">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="400"/>
                <RowDefinition Height="30" MinHeight="30"/>
            </Grid.RowDefinitions>

            <!-- 图片显示和缩略图区域 -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="600"/>
                    <ColumnDefinition Width="240" MinWidth="200"/>
                </Grid.ColumnDefinitions>

                <!-- 图片显示区域 -->
                <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="0,0,1,0">
                    <ScrollViewer x:Name="scrollViewer" 
                                  HorizontalScrollBarVisibility="Auto" 
                                  VerticalScrollBarVisibility="Auto"
                                  CanContentScroll="True">
                        <Grid>
                            <Image Source="{Binding CurrentImagePath}"
                                   RenderTransformOrigin="0.5,0.5"
                                   Stretch="Uniform">
                                <Image.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="{Binding ZoomScale}"
                                                       ScaleY="{Binding ZoomScale}"/>
                                        <RotateTransform Angle="{Binding RotationAngle}"/>
                                    </TransformGroup>
                                </Image.RenderTransform>
                            </Image>
                        </Grid>
                    </ScrollViewer>
                </Border>

                <!-- 缩略图列表区域 -->
                <Border Grid.Column="1" Background="#F5F5F5">
                    <StackPanel>
                        <TextBlock Text="当前文件夹图片" 
                                   FontWeight="Bold" 
                                   Margin="10,10,10,5"
                                   HorizontalAlignment="Center"/>

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      MaxHeight="500">
                            <ListBox ItemsSource="{Binding ImageThumbnails}"
                                     SelectedItem="{Binding SelectedThumbnail}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5" Orientation="Horizontal">
                                            <Image Source="{Binding ThumbnailImage}" 
                                                           Width="60" Height="60" 
                                                           Stretch="Uniform"
                                                           Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding FileName}" 
                                                               VerticalAlignment="Center"
                                                               TextWrapping="Wrap"
                                                               MaxWidth="120"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 状态栏 -->
            <Border Grid.Row="1"
                    BorderBrush="Black" 
                    BorderThickness="1">
                <StatusBar Background="#ffffff" Style="{StaticResource StatusBarFontStyle}">
                    <StatusBarItem>
                        <TextBlock Text="{Binding CurrentFileName}" ToolTip="文件名" />
                    </StatusBarItem>

                    <StatusBarItem>
                        <TextBlock Text=" · "/>
                    </StatusBarItem>

                    <StatusBarItem>
                        <TextBlock Text="{Binding ImageDimensions}" ToolTip="图片尺寸"/>
                    </StatusBarItem>

                    <StatusBarItem>
                        <TextBlock Text=" · "/>
                    </StatusBarItem>

                    <StatusBarItem>
                        <TextBlock Text="{Binding ZoomPercent, StringFormat={}{0:F0}%}" 
                                   ToolTip="缩放比例"/>
                    </StatusBarItem>

                    <StatusBarItem>
                        <TextBlock Text=" · "/>
                    </StatusBarItem>

                    <StatusBarItem>
                        <TextBlock Text="{Binding FileSize}" ToolTip="文件大小"/>
                    </StatusBarItem>

                    <StatusBarItem HorizontalAlignment="Right">
                        <Slider Width="150" 
                                Minimum="10" 
                                Maximum="400" 
                                Value="{Binding ZoomPercent}"
                                SmallChange="10"
                                LargeChange="50"
                                ToolTip="调整缩放比例"/>
                    </StatusBarItem>
                </StatusBar>
            </Border>
        </Grid>
    </DockPanel>
</Window>